<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".instructions_popup"
    android:background="@drawable/popupbg"
    >

    <TextView
        android:id="@+id/textView"
        android:layout_width="276dp"
        android:layout_height="48dp"
        android:fontFamily="@font/architects_daughter"
        android:text="INSTRUCTIONS"
        android:textAlignment="center"
        android:textColor="#3882A2"
        android:textSize="34sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.496"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.114" />

    <TextView
        android:id="@+id/textView2"
        android:layout_width="274dp"
        android:layout_height="146dp"
        android:text="Welcome to Pantry Palette. Pick out ingredients, figure out recipes, and press the 'get results' button to see if you've successfully made something delicious!"
        android:textAlignment="center"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView"
        app:layout_constraintVertical_bias="0.0" />

    <TextView
        android:id="@+id/textView3"
        android:layout_width="276dp"
        android:layout_height="131dp"
        android:text="You can pick out multiple ingredients at once. Don't know what to amke? how about a strawberry shortcake! A + B + C + D + E + G + H! "
        android:textAlignment="center"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.496"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView2"
        app:layout_constraintVertical_bias="0.0" />

    <Button
        android:id="@+id/closeBtn"
        android:layout_width="133dp"
        android:layout_height="60dp"
        android:backgroundTint="#816EA2"
        android:fontFamily="@font/architects_daughter"
        android:text="Close"
        android:textAlignment="center"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView3"
        app:layout_constraintVertical_bias="0.44" />

    <TextView
        android:id="@+id/textView13"
        android:layout_width="268dp"
        android:layout_height="95dp"
        android:fontFamily="sans-serif"
        android:text="hint: a chocolate cake is almost the same as the strawberry, but minus C and E from the equation"
        android:textAlignment="center"
        android:textColor="#3881A1"
        android:textSize="18sp"
        android:textStyle="bold|italic"
        app:layout_constraintBottom_toTopOf="@+id/closeBtn"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.524"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView3"
        app:layout_constraintVertical_bias="0.0" />
</androidx.constraintlayout.widget.ConstraintLayout>